{
  "name": "conflictzero",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:core": "node --experimental-strip-types --test packages/core/test/core.test.ts packages/core/test/golden-vector.test.ts",
    "test:contract": "node --test contract/test/protocol-model.test.mjs",
    "test:adapter": "node --test packages/midnight-adapter/test/adapter.test.ts",
    "test": "npm run test:core && npm run test:contract && npm run test:adapter"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "0.16.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vite-plugin-wasm": "^3.6.0"
  }
}
