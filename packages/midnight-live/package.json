{
  "name": "@conflictzero/midnight-live",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Optional real Midnight execution harness for ConflictZero",
  "scripts": {
    "check": "tsc --noEmit",
    "build": "esbuild src/deploy-and-prove.ts --bundle --platform=node --format=esm --external:level --external:@midnight-ntwrk/compact-runtime --external:@midnight-ntwrk/onchain-runtime-v3 --banner:js=\"import { createRequire } from 'node:module'; const require = createRequire(import.meta.url);\" --outfile=dist/deploy-and-prove.mjs",
    "postbuild": "cp node_modules/@midnight-ntwrk/ledger-v8/midnight_ledger_wasm_bg.wasm node_modules/@midnight-ntwrk/onchain-runtime-v3/midnight_onchain_runtime_wasm_bg.wasm node_modules/@midnight-ntwrk/zkir-v2/midnight_zkir_wasm_bg.wasm dist/",
    "devnet:up": "docker compose up -d --wait",
    "devnet:down": "docker compose down",
    "deploy-and-prove": "npm run build --silent && node dist/deploy-and-prove.mjs"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "0.16.0",
    "@midnight-ntwrk/midnight-js-contracts": "4.1.1",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-network-id": "4.1.1",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-protocol": "4.1.1",
    "@midnight-ntwrk/wallet-sdk": "1.2.0",
    "rxjs": "^7.8.2",
    "ws": "^8.21.1"
  },
  "devDependencies": { "@types/node": "^22.0.0", "@types/ws": "^8.18.1", "esbuild": "0.28.1", "tsx": "^4.23.1", "typescript": "^6.0.3" },
  "engines": { "node": ">=22" }
}
